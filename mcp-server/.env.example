# ─── MCP HTTP transport ───────────────────────────────────────────────
# MCP_AUTH_TOKEN must match the Bearer header configured in your MCP client
# (e.g. .mcp.json `headers.Authorization`). Rotation: update both and restart.
# Generate with: openssl rand -hex 32
MCP_HOST=0.0.0.0
MCP_PORT=3105
MCP_AUTH_TOKEN=sk-sankhya-ajuda-CHANGE_ME
MCP_BODY_LIMIT_BYTES=4000000

# ─── Session lifecycle (Gap 2 fix v1.5.2) ─────────────────────────────
# Idle session timeout — 0 disables cleanup. Default 30 min.
SESSION_IDLE_TIMEOUT_MS=1800000
# How often the reaper runs.
SESSION_CLEANUP_INTERVAL_MS=60000

# ─── PostgreSQL (sankhya_ajuda schema populated by Phase 1 ETL) ───────
PG_HOST=127.0.0.1
PG_PORT=5433
PG_DATABASE=sankhya_ajuda
PG_USER=sankhya_ajuda
PG_PASSWORD=
PG_POOL_MIN=1
PG_POOL_MAX=4

# ─── Embeddings provider (v1.5.3) ─────────────────────────────────────
# Pick ONE — the DB MUST be indexed with the same model used at query time.
# Cross-model cosine similarity is mathematically invalid (SPEC RF07/AD-003).
#
#   vllm   = local vLLM (DEFAULT, SkillsIT infra; DB indexed Qwen3 2560d)
#   openai = OpenAI text-embedding-3-large @ 2560 dims (DB must be re-indexed
#            with OpenAI vectors for semantic to be meaningful)
#   none   = no embeddings; every search forced to mode=keyword (FTS only).
#            Use this when neither vLLM nor an OpenAI key are available.
EMBEDDING_PROVIDER=vllm

# ─── vLLM — used when EMBEDDING_PROVIDER=vllm ─────────────────────────
# REQUIRED if EMBEDDING_PROVIDER=vllm. No hardcoded default in code — boot will
# fail loud with a clear message if missing. Replace with your own endpoint.
VLLM_BASE_URL=http://vllm.example.com:8090/v1
VLLM_API_KEY=
VLLM_MODEL=Qwen/Qwen3-Embedding-4B
VLLM_TIMEOUT_MS=60000

# ─── OpenAI — used when EMBEDDING_PROVIDER=openai ─────────────────────
# `EMBEDDING_FALLBACK_OPENAI` is DEPRECATED v1.5.3 — there is no cross-model
# automatic fallback. Choose the primary provider via EMBEDDING_PROVIDER above.
EMBEDDING_FALLBACK_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=text-embedding-3-large

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info
TENANT_LABEL=skillsit
