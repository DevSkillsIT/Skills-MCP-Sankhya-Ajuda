# =============================================================================
# .env — PHASE 1 (Python ETL) configuration
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in. NEVER commit `.env` (already gitignored).
#
# The MCP server (Phase 2) reads a SEPARATE .env at `mcp-server/.env` — see
# `mcp-server/.env.example` for that one. Variables that overlap (PG_*, VLLM_*)
# must be kept in sync between the two files.
# =============================================================================

# ------------------------------------------------------------
# PostgreSQL (external container — set to your host)
# ------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5433
PG_DB=sankhya_ajuda
PG_USER=sankhya_ajuda
PG_PASSWORD=

# ------------------------------------------------------------
# vLLM embeddings (Qwen3-embedding-4b, 2560 dims) — required for sync
# Set VLLM_BASE_URL to your own vLLM endpoint (no default — code requires it).
# ------------------------------------------------------------
VLLM_BASE_URL=http://vllm.example.com:8090/v1
VLLM_API_KEY=
VLLM_MODEL=/model
VLLM_DIMENSIONS=2560
VLLM_TIMEOUT=60

# ------------------------------------------------------------
# Sankhya Help Center (Zendesk public API)
# ------------------------------------------------------------
SANKHYA_HC_BASE=https://ajuda.sankhya.com.br
SANKHYA_HC_LOCALE=pt-br
SANKHYA_HC_PER_PAGE=100
SANKHYA_HC_DELAY=0.3
SANKHYA_HC_USER_AGENT=sankhya_ajuda-mcp/0.1 (+contact: youremail@example.com)

# ------------------------------------------------------------
# Sync behavior
# ------------------------------------------------------------
SYNC_LOG_LEVEL=INFO

# =============================================================================
# NOTE: MCP server (Bearer auth, HTTP transport) lives in mcp-server/.env
# Generate the token with:  openssl rand -hex 32
# Then set it in mcp-server/.env as:  MCP_AUTH_TOKEN=sk-sankhya-ajuda-<hex>
# The same value must go in your MCP client config (Claude/Cursor/etc).
# See mcp-server/.env.example for the full Phase-2 configuration.
# =============================================================================
